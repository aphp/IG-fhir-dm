{
  "resourceType": "ViewDefinition",
  "name": "observation_composite",
  "resource": "Observation",
  "select": [
    {
      "column": [
        { "path": "getResourceKey()", "name": "observation_id" },
        { "path": "meta.profile.first()", "name": "profile" },
        { "path": "status", "name": "status" },
        { "path": "subject.getReferenceKey()", "name": "patient_id" },
        { "path": "effectiveDateTime", "name": "effective_date_time" },
        { "path": "category.first().coding.first().code", "name": "category_code" },
        { "path": "code.coding.first().code", "name": "loinc_code" }
      ]
    },
    {
      "column": [
        { "path": "code.coding.first().code", "name": "component_loinc_code" },
        { "path": "valueQuantity.value", "name": "component_value" },
        { "path": "valueQuantity.unit", "name": "component_unit" }
      ],
      "forEach": "component"
    }
  ],
  "where": [
    { "path": "component.exists()" }
  ]
}