{
  "resourceType": "ViewDefinition",
  "name": "fhir_observation_blood_pressure",
  "resource": "Observation",
  "select": [
    {"column": [
        {"path": "id","name": "observation_id"},
        {"path": "status","name": "statut"},
        {"path": "subject.reference","name": "patient_reference"},
        {"path": "effectiveDateTime","name": "date_mesure"},
        {"path": "category.first().coding.first().system","name": "categorie_system"},
        {"path": "category.first().coding.first().code","name": "categorie_code"},
        {"path": "code.coding.first().system","name": "code_system"},
        {"path": "code.coding.first().code","name": "code_loinc"},
        {"path": "code.coding.first().display","name": "libelle"}
      ]},
    {"column": [
        {"path": "code.coding.first().code","name": "component_loinc_code"},
        {"path": "code.coding.first().display","name": "component_libelle"},
        {"path": "valueQuantity.value","name": "component_valeur"},
        {"path": "valueQuantity.unit","name": "component_unite"},
        {"path": "valueQuantity.system","name": "component_unite_system"}
      ],
      "forEach": "component"
    }
  ],
  "where": [
    {
      "path": "component.exists()"
    }
  ]
}