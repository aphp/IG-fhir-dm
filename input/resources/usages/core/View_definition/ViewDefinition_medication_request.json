{
  "resourceType": "ViewDefinition",
  "name": "medication_request",
  "resource": "MedicationRequest",
  "select": [
    {
      "column": [
        { "path": "getResourceKey()", "name": "medication_request_id" },
        { "path": "subject.getReferenceKey()", "name": "patient_id" },
        { "path": "status", "name": "status" },
        { "path": "intent", "name": "intent" },
        { "path": "medication.ofType(CodeableConcept).coding.first().code", "name": "medication_code" },
        { "path": "medication.ofType(CodeableConcept).coding.first().display", "name": "medication_name" },
        { "path": "dosageInstruction.first().timing.repeat.bounds.ofType(Period).start", "name": "dose_start" },
        { "path": "dosageInstruction.first().timing.repeat.bounds.ofType(Period).end", "name": "dose_end" },
        { "path": "dosageInstruction.first().route.coding.first().code", "name": "route_code" }
      ]
    }
  ]
}